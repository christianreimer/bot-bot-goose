# Copy to deploy/compose.env and fill in. Never commit the real file.

# Public hostname Caddy should TLS for. "localhost" works for local play.
BBG_DOMAIN=localhost

# Public URL used in share artifacts and magic-link emails.
BBG_BASE_URL=http://localhost

# 32+ random bytes, hex-encoded. Used to sign device cookies and play tokens.
# generate with: openssl rand -hex 32
BBG_SESSION_KEY=

# Postgres. POSTGRES_PASSWORD is REQUIRED — compose refuses to start without it.
# Generate with: openssl rand -hex 24
POSTGRES_USER=bbg
POSTGRES_PASSWORD=
POSTGRES_DB=bbg

# Web Push (VAPID). Generate with: go run ./cmd/admin vapid-gen
BBG_VAPID_PUBLIC=
BBG_VAPID_PRIVATE=

# For cmd/bot-candidates. Never read by the live server.
BBG_ANTHROPIC_API_KEY=

# Magic-link email. "log" prints links to stdout (fine for dev). Production
# uses "resend": fill BBG_RESEND_API_KEY with the key from your Resend
# dashboard. The FROM domain (botbotgoose.fun) must be verified there.
BBG_EMAIL_PROVIDER=resend
BBG_RESEND_API_KEY=
BBG_EMAIL_FROM=Bot Bot Goose <contact@botbotgoose.fun>
