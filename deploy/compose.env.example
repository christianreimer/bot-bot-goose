# Copy to deploy/compose.env and fill in. Never commit the real file.

# Public hostname Caddy should TLS for. "localhost" works for local play.
BBG_DOMAIN=localhost

# Public URL used in share artifacts and magic-link emails.
BBG_BASE_URL=http://localhost

# 32+ random bytes, hex-encoded. Used to sign device cookies and play tokens.
# generate with: openssl rand -hex 32
BBG_SESSION_KEY=

# Postgres. POSTGRES_PASSWORD is REQUIRED — compose refuses to start without it.
# Generate with: openssl rand -hex 24
POSTGRES_USER=bbg
POSTGRES_PASSWORD=
POSTGRES_DB=bbg

# Pool sizing for the launch. See plans/launch-capacity.md §1.2. Defaults
# in code are 64 / 8 — only override here when the managed Postgres plan
# has a lower connection ceiling.
#BBG_DB_MAX_CONNS=64
#BBG_DB_MIN_CONNS=8

# ---- prod-only overrides ----------------------------------------------------
# In dev (`make up`, profile=local) the bbg container talks to the bundled
# postgres and valkey services on the compose network — no overrides needed.
# In prod (`make up-prod`, profile=edge) those bundled services aren't
# started; the operator MUST set the two URLs below to the DO managed
# instances or bbg will fail to connect at boot. See plans/launch-capacity
# §5.2 + §5.3.
#BBG_DB_URL=postgres://bbg:CHANGEME@private-pool.../bbg?sslmode=require
#BBG_VALKEY_URL=rediss://default:CHANGEME@private-cache.../0

# Optional second listener for /metrics. The launch-capacity plan §1.6
# keeps this off the public Caddy/Cloudflare path; bind to loopback or
# a private IP. Empty = metrics counters still maintained but not served
# over HTTP.
#BBG_METRICS_LISTEN=127.0.0.1:8081

# Web Push (VAPID). Generate with: go run ./cmd/admin vapid-gen
BBG_VAPID_PUBLIC=
BBG_VAPID_PRIVATE=

# For cmd/bot-candidates. Never read by the live server.
BBG_ANTHROPIC_API_KEY=

# Magic-link email. "log" prints links to stdout (fine for dev). Production
# uses "resend": fill BBG_RESEND_API_KEY with the key from your Resend
# dashboard. The FROM domain (botbotgoose.fun) must be verified there.
BBG_EMAIL_PROVIDER=resend
BBG_RESEND_API_KEY=
BBG_EMAIL_FROM=Bot Bot Goose <contact@botbotgoose.fun>
