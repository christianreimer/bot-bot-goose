# Build artifacts (`make build` writes here)
/bin/
# Stray ad-hoc binary from `go build ./cmd/admin` at the repo root
/admin

# Local DB dumps
/backups/

# Local-only env files. compose.env carries BBG_SESSION_KEY + POSTGRES_PASSWORD;
# never commit it. compose.env.example IS committed (template only).
/deploy/compose.env
/deploy/secrets/
*.env
.env
.env.local
.env.*.local

# Go test + coverage + profile artifacts
*.test
*.out
coverage.out
*.prof

# Editor / IDE / Agent tooling
.vscode/
.idea/
.cursor/
.claude/
*.iml
*.swp
*.swo

# OS cruft
.DS_Store
._*
Thumbs.db
desktop.ini

# Logs
*.log

# Any stray cert / key material
*.pem
*.key
*.crt
*.csr
*.p12

# Local Cloudflare Quick Tunnel state — `make up` writes here. The PID
# and the trycloudflare.com URL change every restart; nothing here is
# worth committing.
/.tunnel/

# Scratch
/tmp/
